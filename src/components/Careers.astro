---
import RoleRow from "./RoleRow.astro";

interface Role {
  slug: string;
  order: number;
  rowTitle: string;
  rowType: string;
  rowTeam: string;
}

const modules = import.meta.glob<{ default: Role } | Role>(
  "../data/roles/*.json",
  { eager: true },
);
const roles = Object.values(modules)
  .map((mod) => (("default" in mod ? mod.default : mod) as Role))
  .sort((a, b) => a.order - b.order);

const pad2 = (n: number) => String(n).padStart(2, "0");
---

<section class="light careers" id="careers">
  <div class="wrap section-pad">
    <div class="header-row">
      <div>
        <div class="eyebrow reveal">Careers</div>
        <h2 class="reveal d1">Come work with us.</h2>
      </div>
      <p class="reveal d2">
        We are a small team building the vehicles an orbital economy depends on. Come build them with us.
      </p>
    </div>

    <div class="roles">
      {
        roles.map((r) => (
          <RoleRow
            number={pad2(r.order)}
            title={r.rowTitle}
            type={r.rowType}
            team={r.rowTeam}
            href={`/careers/${r.slug}`}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .careers .header-row {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-grid);
    align-items: end;
    margin-bottom: var(--space-section-head);
  }
  @media (max-width: 860px) {
    .careers .header-row {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
  }
  .careers .header-row h2 {
    font-family: var(--font-display);
    font-weight: 500;
    letter-spacing: var(--tracking-display);
    font-size: var(--fs-display-lg);
    line-height: 1.04;
    max-width: 18ch;
  }
  .careers .header-row p {
    font-size: clamp(15px, 1.3vw, 16px);
    line-height: 1.55;
    color: var(--ink-soft);
    max-width: 42ch;
  }
  .roles {
    border-top: 1px solid var(--rule-light);
  }
</style>
