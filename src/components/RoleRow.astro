---
interface Props {
  number: string;
  title: string;
  type: string;
  team: string;
  href: string;
}

const { number, title, type, team, href } = Astro.props;
---

<a class="role reveal" href={href} target="_blank" rel="noopener">
  <span class="num">{number}</span>
  <span class="title">{title}</span>
  <span class="meta-cell">{type}</span>
  <span class="meta-cell">{team}</span>
  <span class="arr">&#8599;</span>
</a>

<style>
  .role {
    display: grid;
    grid-template-columns: auto 1fr auto auto auto;
    gap: var(--space-role-gap);
    align-items: center;
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--rule-light);
    text-decoration: none;
    color: var(--ink);
    transition: padding-left 0.25s;
  }
  .role:hover {
    padding-left: var(--space-2);
  }
  .num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--faring-700);
    min-width: var(--space-4);
  }
  .title {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(19px, 2.1vw, 26px);
    letter-spacing: -0.01em;
  }
  .meta-cell {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: var(--faring-700);
    white-space: nowrap;
  }
  .arr {
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--ink);
    transition: transform 0.25s;
  }
  .role:hover .arr {
    transform: translate(4px, -4px);
  }
  @media (max-width: 760px) {
    .role {
      grid-template-columns: auto 1fr auto;
      row-gap: var(--space-2);
    }
    .meta-cell {
      grid-column: 2 / 3;
      font-size: 10px;
    }
    .num {
      grid-row: 1 / 3;
    }
  }
</style>
