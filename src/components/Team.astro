---
import data from "../data/team.json";

interface Member {
  name: string;
  photo: string | null;
  title: string;
  description: string;
  linkedin?: string;
}

const initials = (name: string) =>
  name
    .split(/\s+/)
    .map((w) => w[0])
    .slice(0, 2)
    .join("")
    .toUpperCase();

const founders = data.founders as Member[];
const investors = data.investors as Member[];
const renderMember = (m: Member, slot: number) => ({ m, slot });

const founderSlots = founders.map((m, i) => renderMember(m, i + 1));
const investorSlots = investors.map((m, i) => renderMember(m, founders.length + i + 1));
const allSlots = [...founderSlots, ...investorSlots];
---

<section class="light team" id="team">
  <div class="wrap section-pad">
    <div class="section-head">
      <div class="eyebrow reveal">The team</div>
      <h2 class="reveal d1">Who's behind it.</h2>
    </div>

    <div class="team-grid">
      <div class="group-label label-founders reveal d2">Founders</div>
      <div class="group-label label-investor reveal d3">Founding investor</div>

      {
        allSlots.map(({ m, slot }) => (
          <article class={`team-card card-${slot}`}>
            <div class="photo">
              {m.photo ? (
                <img src={m.photo} alt={m.name} width="700" height="1050" />
              ) : (
                <div class="photo-placeholder">{initials(m.name)}</div>
              )}
            </div>
            <h3>{m.name}</h3>
            <p class="title">{m.title}</p>
            {m.description && <p class="bio">{m.description}</p>}
            {m.linkedin && (
              <a
                class="card-link"
                href={m.linkedin}
                target="_blank"
                rel="noopener"
                aria-label={`${m.name} on LinkedIn`}
              />
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-areas:
      "lf lf li"
      "c1 c2 c3";
    column-gap: var(--space-4);
    row-gap: var(--space-4);
    align-items: start;
    margin-top: var(--space-section-head);
  }
  .label-founders { grid-area: lf; }
  .label-investor { grid-area: li; }
  .card-1 { grid-area: c1; }
  .card-2 { grid-area: c2; }
  .card-3 { grid-area: c3; }

  @media (max-width: 860px) {
    .team-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-areas:
        "lf lf"
        "c1 c2"
        "li li"
        "c3 c3";
    }
    .card-3 {
      max-width: 50%;
    }
  }
  @media (max-width: 600px) {
    .team-grid {
      grid-template-columns: 1fr;
      grid-template-areas:
        "lf"
        "c1"
        "c2"
        "li"
        "c3";
    }
    .card-3 {
      max-width: none;
    }
  }

  .group-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    color: var(--faring-700);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule-light);
  }

  .team-card {
    position: relative;
    border: 1px solid var(--rule-light);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    background: var(--paper);
    transition: border-color 0.25s;
  }
  .team-card:has(.card-link:hover) {
    border-color: var(--ink);
    cursor: pointer;
  }
  .card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .photo {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 100%;
    overflow: hidden;
    background: var(--paper-2);
  }
  .photo img,
  .photo-placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .photo-placeholder {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(40px, 5vw, 56px);
    letter-spacing: -0.02em;
    color: var(--faring-500);
  }

  .team-card h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 26px);
    letter-spacing: -0.01em;
    line-height: 1.05;
    color: var(--ink);
    text-transform: uppercase;
    margin: 0;
  }
  .team-card .title {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    color: var(--faring-700);
    margin: 0;
  }
  .team-card .bio {
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0;
  }
</style>
