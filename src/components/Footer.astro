<footer>
  <div class="footer-grid">
    <div class="footer-col">
      <a href="/" class="footer-brand" aria-label="P78 — home">
        <img src="/logo.svg" alt="P78" />
      </a>
      <div class="footer-tag">
        The logistics layer of the in-space economy.
      </div>
    </div>
    <div class="footer-col">
      <div class="footer-h">Site</div>
      <a href="/#mission">Mission</a>
      <a href="/#products">Products</a>
      <a href="/#careers">Careers</a>
    </div>
    <div class="footer-col">
      <div class="footer-h">Contact</div>
      <a href="mailto:contact@p78space.com">contact@p78space.com</a>
      <a href="/#partner">Partner with us</a>
    </div>
    <div class="footer-col">
      <div class="footer-h">Elsewhere</div>
      <a href="https://www.instagram.com/p78space/" target="_blank">Instagram</a>
    </div>
  </div>
  <div class="footer-base">
    <span>P78 Space &middot; &copy; 2026</span>
    <span>
      Imagery courtesy of
      <a href="https://images.nasa.gov/" target="_blank" rel="noopener">NASA</a>
    </span>
    <span><a href="/privacy">Privacy</a></span>
    <span>Space logistics specialists</span>
  </div>
</footer>

<style>
  footer {
    background: var(--ink);
    color: var(--paper);
    border-top: 1px solid var(--rule);
    padding: var(--space-5) 0 var(--space-4);
  }
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    align-items: start;
    padding: 0 var(--space-4);
  }
  @media (max-width: 760px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-4);
    }
  }
  .footer-col .footer-h {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    color: var(--faring-300);
    font-weight: 500;
    margin-bottom: var(--space-3);
  }
  .footer-col a {
    display: block;
    color: var(--paper);
    text-decoration: none;
    font-size: 14px;
    padding: var(--space-1) 0;
    opacity: 0.82;
    transition: opacity 0.25s;
  }
  .footer-col a:hover {
    opacity: 1;
  }
  .footer-brand {
    display: inline-block;
    margin-bottom: var(--space-3);
  }
  .footer-brand img {
    display: block;
    height: 28px;
    width: auto;
  }
  .footer-tag {
    font-size: 13px;
    color: var(--faring-300);
    line-height: 1.5;
    max-width: 30ch;
  }
  .footer-base {
    margin-top: var(--space-5);
    padding: var(--space-4) var(--space-4) 0;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faring-300);
  }
  .footer-base a {
    color: var(--faring-300);
    text-decoration: none;
    transition: color 0.25s;
  }
  .footer-base a:hover {
    color: var(--paper);
  }
</style>
