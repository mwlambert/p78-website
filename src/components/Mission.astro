---

<section class="light mission" id="mission">
  <div class="wrap section-pad">
    <div class="section-head">
      <div class="eyebrow reveal">Why now</div>
      <h2 class="reveal d1">
        Getting to orbit is the easy part. Working there isn't.
      </h2>
    </div>

    <div class="mission-grid">
      <div class="mission-block reveal d2">
        <div class="col-label">Why P78</div>
        <div class="caps">
          <div class="cap">
            <span class="num">P / 1</span>
            <h3>Propulsion</h3>
            <p>Legacy systems are toxic, slow, and expensive.</p>
          </div>
          <div class="cap">
            <span class="num">P / 2</span>
            <h3>Reuse</h3>
            <p>Every asset launches with a fixed operational life.</p>
          </div>
          <div class="cap">
            <span class="num">P / 3</span>
            <h3>Reach</h3>
            <p>The Moon and in-orbit assets stay out of routine reach.</p>
          </div>
        </div>
      </div>

      <div class="mission-block reveal d3">
        <div class="col-label">What we do</div>
        <div class="caps">
          <div class="cap">
            <span class="num">01</span>
            <h3>Propulsion</h3>
            <p>HTP engines for reusable spacecraft.</p>
          </div>
          <div class="cap">
            <span class="num">02</span>
            <h3>Vehicle</h3>
            <p>Refuelable vehicles with cislunar range.</p>
          </div>
          <div class="cap">
            <span class="num">03</span>
            <h3>Logistics</h3>
            <p>Routing, servicing, and supply across the in-space economy.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Mission triad cascade. When each .caps block enters view, the rows
  // fade-and-rise in sequence (transition delays handled in CSS via
  // nth-child). Since the two columns sit in a shared grid row, they
  // come into view together — P/1 pairs with 01, P/2 with 02, P/3 with
  // 03 as the user reads down. prefers-reduced-motion handled in CSS.
  const prefersReduced = matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (!prefersReduced) {
    const blocks = document.querySelectorAll(".mission-block .caps");
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target
              .querySelectorAll(".cap")
              .forEach((cap) => cap.classList.add("in"));
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 },
    );
    blocks.forEach((b) => observer.observe(b));
  }
</script>

<style>
  .mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-grid);
    margin-top: var(--space-section-head);
    align-items: start;
  }
  @media (max-width: 860px) {
    .mission-grid {
      grid-template-columns: 1fr;
      gap: var(--space-section-head);
    }
  }
  .col-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: var(--tracking-mono);
    text-transform: uppercase;
    color: var(--faring-700);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--rule-light);
  }
  .caps {
    display: flex;
    flex-direction: column;
  }
  .cap {
    display: grid;
    grid-template-columns: auto minmax(110px, max-content) 1fr;
    gap: var(--space-3);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--rule-light);
    align-items: baseline;
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.7s cubic-bezier(0.2, 0.7, 0.2, 1),
      transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .cap.in {
    opacity: 1;
    transform: none;
  }
  .caps .cap:nth-child(1) { transition-delay: 0s; }
  .caps .cap:nth-child(2) { transition-delay: 0.15s; }
  .caps .cap:nth-child(3) { transition-delay: 0.3s; }

  @media (prefers-reduced-motion: reduce) {
    .cap,
    .cap.in {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
  .cap .num {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    color: var(--ink);
  }
  .cap h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(17px, 1.7vw, 21px);
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .cap p {
    font-size: clamp(14px, 1.2vw, 15px);
    line-height: 1.5;
    color: var(--faring-700);
    margin: 0;
  }

  @media (max-width: 760px) {
    .cap {
      grid-template-columns: auto 1fr;
      row-gap: var(--space-2);
    }
    .cap p {
      grid-column: 2 / 3;
    }
  }
</style>
