<nav>
  <div class="nav-in">
    <a href="/#top" class="brand" aria-label="P78 — home">
      <img src="/logo.svg" alt="P78" />
    </a>
    <div class="navlinks">
      <a href="/#mission">Mission</a>
      <a href="/#products">Products</a>
      <a href="/#careers">Careers</a>
      <a href="/#partner">Partner with us</a>
